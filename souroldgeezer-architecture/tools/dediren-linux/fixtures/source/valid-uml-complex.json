            {
              "name": "transactionId",
              "type": "String",
              "visibility": "private",
              "multiplicity": "0..1"
            },
            {
              "name": "state",
              "type": "PaymentState",
              "visibility": "private",
              "multiplicity": "1"
            },
            {
              "name": "order",
              "type": "Order",
              "visibility": "public",
              "multiplicity": "1"
            }
          ],
          "operations": [
            {
              "name": "capture",
              "visibility": "public",
              "parameters": [],
              "return_type": "PaymentState"
            }
          ]
        }
      }
    },
    {
      "id": "class-shipment",
      "type": "Class",
      "label": "Shipment",
