          "label": "Commerce Fulfillment Data Model",
          "kind": "uml-data",
          "nodes": [
            "class-customer",
            "class-order",
            "class-order-line",
            "class-shipment",
            "datatype-order-id",
            "datatype-money",
            "datatype-address",
            "enum-order-status",
            "enum-payment-state",
            "enum-shipment-state"
          ],
          "relationships": [
            "customer-places-order",
            "order-has-lines",
            "order-status-dependency",
            "order-total-money",
            "order-line-unit-price-money",
            "order-id-type",
            "shipment-destination",
            "shipment-state"
          ],
          "layout_preferences": {
            "direction": "right",
            "density": "readable",
            "routing": {
              "style": "orthogonal",
              "profile": "readable",
              "endpoint_merging": "off"
            }
          }
        },
        {
          "id": "complex-activity-view",
          "label": "Fulfill Order Activity",
          "kind": "uml-activity",
          "nodes": [
            "activity-fulfill-order",
            "initial-fulfill",
            "action-load-order",
            "decision-payment-ok",
            "action-reserve-stock",
            "fork-fulfillment",
            "action-pack-order",
            "action-create-label",
            "object-shipment",
            "join-fulfillment",
            "final-fulfill"
          ],
          "relationships": [
            "flow-start-load",
            "flow-load-payment",
            "flow-paid-reserve",
            "flow-reserve-fork",
            "flow-fork-pack",
            "flow-fork-label",
            "flow-pack-join",
            "flow-label-shipment",
            "flow-shipment-join",
            "flow-join-final"
          ],
          "layout_preferences": {
            "direction": "right",
            "density": "spacious",
            "routing": {
              "style": "orthogonal",
              "profile": "spacious",
              "endpoint_merging": "off"
