        "uml": {
          "package": "pkg-fulfillment",
          "attributes": [
            {
              "name": "trackingNumber",
              "type": "String",
              "visibility": "public",
              "multiplicity": "0..1"
            },
            {
              "name": "order",
              "type": "Order",
              "visibility": "public",
              "multiplicity": "1"
            },
            {
              "name": "destination",
              "type": "Address",
              "visibility": "public",
              "multiplicity": "1"
            },
            {
              "name": "state",
              "type": "ShipmentState",
              "visibility": "private",
              "multiplicity": "1"
            }
          ],
          "operations": [
            {
              "name": "dispatch",
              "visibility": "public",
              "parameters": [],
              "return_type": "void"
            }
          ]
        }
      }
    },
