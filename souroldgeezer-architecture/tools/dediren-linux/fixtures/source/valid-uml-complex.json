          "id": "complex-class-view",
          "label": "Commerce Fulfillment Class Model",
          "kind": "uml-class",
          "nodes": [
            "class-customer",
            "class-order",
            "class-order-line",
            "enum-order-status",
            "datatype-order-id",
            "datatype-money",
            "interface-payment-gateway",
            "class-card-payment",
            "enum-payment-state",
            "class-shipment",
            "datatype-address",
            "enum-shipment-state"
