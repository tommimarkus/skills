      "type": "Class",
      "label": "OrderLine",
      "properties": {
        "uml": {
          "package": "pkg-commerce",
          "attributes": [
            {
              "name": "sku",
              "type": "String",
              "visibility": "public",
              "multiplicity": "1"
            },
            {
              "name": "quantity",
              "type": "Integer",
              "visibility": "public",
              "multiplicity": "1"
            },
            {
              "name": "unitPrice",
              "type": "Money",
              "visibility": "public",
              "multiplicity": "1"
            },
            {
              "name": "order",
              "type": "Order",
              "visibility": "public",
              "multiplicity": "1"
            }
          ],
          "operations": []
        }
      }
    },
    {
