      "type": "ObjectNode",
      "label": "Shipment",
      "properties": {
        "uml": {
          "activity": "activity-fulfill-order",
          "type": "Shipment"
        }
      }
    },
    {
      "id": "final-fulfill",
      "type": "ActivityFinalNode",
      "label": "",
      "properties": {
        "uml": {
          "activity": "activity-fulfill-order",
          "partition": "Warehouse"
        }
      }
    }
  ],
  "relationships": [
    {
      "id": "customer-places-order",
      "type": "Association",
      "source": "class-customer",
      "target": "class-order",
      "label": "places",
      "properties": {
        "uml": {
          "source_role": "customer",
          "target_role": "orders",
          "source_multiplicity": "1",
          "target_multiplicity": "0..*"
        }
      }
    },
    {
      "id": "order-has-lines",
      "type": "Composition",
      "source": "class-order",
      "target": "class-order-line",
      "label": "lines",
      "properties": {
        "uml": {
          "source_role": "order",
          "target_role": "lines",
          "source_multiplicity": "1",
          "target_multiplicity": "1..*"
        }
      }
    },
    {
      "id": "order-has-payment",
      "type": "Aggregation",
      "source": "class-order",
      "target": "class-card-payment",
      "label": "payment",
      "properties": {
        "uml": {
          "source_role": "order",
          "target_role": "payment",
          "source_multiplicity": "1",
          "target_multiplicity": "0..1"
        }
      }
    },
    {
      "id": "order-status-dependency",
      "type": "Dependency",
      "source": "class-order",
      "target": "enum-order-status",
      "label": "status",
      "properties": {}
    },
    {
      "id": "order-total-money",
      "type": "Association",
      "source": "class-order",
      "target": "datatype-money",
      "label": "total",
      "properties": {}
    },
    {
      "id": "order-line-unit-price-money",
      "type": "Association",
      "source": "class-order-line",
      "target": "datatype-money",
      "label": "unit price",
      "properties": {}
    },
    {
      "id": "order-id-type",
      "type": "Dependency",
      "source": "class-order",
      "target": "datatype-order-id",
      "label": "id type",
      "properties": {}
    },
    {
      "id": "card-payment-realizes-gateway",
      "type": "Realization",
      "source": "class-card-payment",
      "target": "interface-payment-gateway",
      "label": "implements",
      "properties": {}
    },
    {
      "id": "card-payment-state",
      "type": "Dependency",
      "source": "class-card-payment",
      "target": "enum-payment-state",
      "label": "state",
      "properties": {}
    },
    {
      "id": "shipment-for-order",
      "type": "Association",
      "source": "class-shipment",
      "target": "class-order",
      "label": "ships",
      "properties": {}
    },
    {
      "id": "shipment-destination",
      "type": "Association",
      "source": "class-shipment",
      "target": "datatype-address",
      "label": "ships to",
      "properties": {}
    },
    {
      "id": "shipment-state",
      "type": "Dependency",
      "source": "class-shipment",
      "target": "enum-shipment-state",
      "label": "state",
      "properties": {}
    },
    {
      "id": "flow-start-load",
      "type": "ControlFlow",
      "source": "initial-fulfill",
      "target": "action-load-order",
      "label": "",
      "properties": {}
    },
    {
      "id": "flow-load-payment",
      "type": "ControlFlow",
      "source": "action-load-order",
      "target": "decision-payment-ok",
      "label": "",
      "properties": {}
    },
    {
      "id": "flow-paid-reserve",
      "type": "ControlFlow",
      "source": "decision-payment-ok",
      "target": "action-reserve-stock",
      "label": "paid",
      "properties": {
        "uml": {
          "guard": "paid"
        }
      }
    },
    {
      "id": "flow-reserve-fork",
      "type": "ControlFlow",
      "source": "action-reserve-stock",
      "target": "fork-fulfillment",
      "label": "",
      "properties": {}
    },
    {
      "id": "flow-fork-pack",
      "type": "ControlFlow",
      "source": "fork-fulfillment",
      "target": "action-pack-order",
      "label": "",
      "properties": {}
    },
    {
      "id": "flow-fork-label",
      "type": "ControlFlow",
      "source": "fork-fulfillment",
      "target": "action-create-label",
      "label": "",
      "properties": {}
    },
    {
      "id": "flow-pack-join",
      "type": "ControlFlow",
      "source": "action-pack-order",
      "target": "join-fulfillment",
      "label": "",
      "properties": {}
    },
    {
      "id": "flow-label-shipment",
      "type": "ObjectFlow",
      "source": "action-create-label",
      "target": "object-shipment",
      "label": "label",
      "properties": {}
    },
    {
      "id": "flow-shipment-join",
      "type": "ObjectFlow",
      "source": "object-shipment",
      "target": "join-fulfillment",
      "label": "",
      "properties": {}
    },
    {
      "id": "flow-join-final",
      "type": "ControlFlow",
      "source": "join-fulfillment",
      "target": "final-fulfill",
      "label": "",
      "properties": {}
    }
  ],
