          "attributes": [
            {
              "name": "value",
              "type": "String",
              "visibility": "public",
              "multiplicity": "1"
            }
          ]
        }
      }
    },
    {
      "id": "datatype-money",
      "type": "DataType",
      "label": "Money",
      "properties": {
        "uml": {
          "attributes": [
            {
              "name": "amount",
              "type": "Decimal",
              "visibility": "public",
              "multiplicity": "1"
            },
            {
              "name": "currency",
              "type": "String",
              "visibility": "public",
              "multiplicity": "1"
            }
          ]
        }
      }
    },
    {
      "id": "datatype-address",
      "type": "DataType",
      "label": "Address",
      "properties": {
        "uml": {
          "attributes": [
            {
              "name": "line1",
              "type": "String",
              "visibility": "public",
              "multiplicity": "1"
            },
            {
              "name": "city",
              "type": "String",
              "visibility": "public",
              "multiplicity": "1"
            },
            {
              "name": "country",
              "type": "String",
              "visibility": "public",
              "multiplicity": "1"
            }
          ]
        }
      }
    },
    {
      "id": "enum-order-status",
      "type": "Enumeration",
      "label": "OrderStatus",
      "properties": {
        "uml": {
          "literals": ["Draft", "Submitted", "Paid", "Shipped", "Cancelled"]
        }
      }
    },
    {
      "id": "enum-payment-state",
      "type": "Enumeration",
      "label": "PaymentState",
      "properties": {
        "uml": {
          "literals": ["Authorized", "Captured", "Declined"]
        }
      }
    },
    {
      "id": "enum-shipment-state",
      "type": "Enumeration",
      "label": "ShipmentState",
      "properties": {
        "uml": {
          "literals": ["Pending", "Packed", "Dispatched"]
        }
      }
    },
    {
