              "parameters": [
                {
                  "name": "amount",
                  "type": "Money"
                }
              ],
              "return_type": "PaymentState"
            }
          ]
        }
      }
    },
    {
      "id": "class-card-payment",
      "type": "Class",
      "label": "CardPayment",
      "properties": {
        "uml": {
          "package": "pkg-commerce",
