          "partitions": ["Commerce", "Warehouse", "Carrier"]
        }
      }
    },
    {
      "id": "initial-fulfill",
      "type": "InitialNode",
      "label": "",
      "properties": {
        "uml": {
          "activity": "activity-fulfill-order",
          "partition": "Commerce"
        }
      }
    },
    {
      "id": "action-load-order",
      "type": "Action",
      "label": "Load order",
      "properties": {
        "uml": {
          "activity": "activity-fulfill-order",
          "partition": "Commerce"
        }
      }
    },
    {
      "id": "decision-payment-ok",
      "type": "DecisionNode",
      "label": "Paid?",
      "properties": {
        "uml": {
          "activity": "activity-fulfill-order",
          "partition": "Commerce"
        }
      }
    },
    {
      "id": "action-reserve-stock",
      "type": "Action",
      "label": "Reserve stock",
      "properties": {
        "uml": {
          "activity": "activity-fulfill-order",
          "partition": "Warehouse"
        }
      }
    },
    {
      "id": "fork-fulfillment",
      "type": "ForkNode",
      "label": "",
      "properties": {
        "uml": {
          "activity": "activity-fulfill-order",
          "partition": "Warehouse"
        }
      }
    },
    {
      "id": "action-pack-order",
      "type": "Action",
      "label": "Pack order",
      "properties": {
        "uml": {
          "activity": "activity-fulfill-order",
          "partition": "Warehouse"
        }
      }
    },
    {
      "id": "action-create-label",
      "type": "Action",
      "label": "Create label",
      "properties": {
        "uml": {
          "activity": "activity-fulfill-order",
          "partition": "Carrier"
        }
      }
    },
    {
      "id": "join-fulfillment",
      "type": "JoinNode",
      "label": "",
      "properties": {
        "uml": {
          "activity": "activity-fulfill-order",
          "partition": "Warehouse"
        }
      }
