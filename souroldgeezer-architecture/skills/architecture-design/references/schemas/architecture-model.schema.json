{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://souroldgeezer.dev/schemas/architecture/architecture-model.schema.json",
  "title": "Architecture IR model",
  "type": "object",
  "required": [
    "schemaVersion",
    "feature",
    "archimateTarget",
    "elements",
    "relationships"
  ],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "feature": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "documentation": {
          "type": "string"
        },
        "creator": {
          "type": "string"
        }
      }
    },
    "archimateTarget": {
      "const": "3.2"
    },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "name"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "documentation": {
            "type": "string"
          },
          "authority": {
            "enum": [
              "lifted-from-source",
              "forward-only-or-inferred",
              "architect-approved",
              "stakeholder-validated"
            ]
          },
          "sourceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "source",
          "target"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "documentation": {
            "type": "string"
          },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
