{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://souroldgeezer.dev/schemas/architecture/architecture-layout.schema.json",
  "title": "Architecture IR layout",
  "type": "object",
  "required": [
    "schemaVersion",
    "views"
  ],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "view",
          "intent",
          "geometryPath"
        ],
        "additionalProperties": true,
        "properties": {
          "view": {
            "type": "string",
            "minLength": 1
          },
          "intent": {
            "enum": [
              "preserve-authored",
              "route-repair-only",
              "generated-layout-recreate",
              "global-reflow"
            ]
          },
          "geometryPath": {
            "enum": [
              "layout-elk",
              "route-repair",
              "global-polish",
              "viewpoint-policy",
              "preserved-authored"
            ]
          },
          "nodeLocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "node",
                "x",
                "y",
                "width",
                "height"
              ],
              "additionalProperties": true,
              "properties": {
                "node": {
                  "type": "string",
                  "minLength": 1
                },
                "x": {
                  "type": "integer"
                },
                "y": {
                  "type": "integer"
                },
                "width": {
                  "type": "integer",
                  "minimum": 1
                },
                "height": {
                  "type": "integer",
                  "minimum": 1
                },
                "source": {
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                }
              }
            }
          },
          "routeLocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "connection",
                "bendpoints"
              ],
              "additionalProperties": true,
              "properties": {
                "connection": {
                  "type": "string",
                  "minLength": 1
                },
                "bendpoints": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/point"
                  }
                },
                "source": {
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                }
              }
            }
          },
          "layoutPolicy": {
            "type": "object",
            "required": [
              "name",
              "constraints"
            ],
            "additionalProperties": true,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "strictness": {
                "enum": [
                  "warn",
                  "strict"
                ]
              },
              "constraints": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "kind"
                  ],
                  "additionalProperties": true,
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "kind": {
                      "type": "string",
                      "minLength": 1
                    },
                    "role": {
                      "type": "string"
                    },
                    "direction": {
                      "enum": [
                        "DOWN",
                        "RIGHT",
                        "LEFT",
                        "UP"
                      ]
                    },
                    "nodeIds": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "edgeIds": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                }
              }
            }
          },
          "constraints": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "$defs": {
    "point": {
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "additionalProperties": true,
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        }
      }
    }
  }
}
