{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://souroldgeezer.dev/schemas/architecture/layout-provenance.schema.json",
  "title": "Architecture layout provenance report",
  "type": "object",
  "required": ["schemaVersion", "generatedBy", "views"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "generatedBy": { "type": "string", "minLength": 1 },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/viewProvenance" }
    }
  },
  "$defs": {
    "viewProvenance": {
      "type": "object",
      "required": [
        "viewId",
        "viewpoint",
        "layoutIntent",
        "selectedGeometryPath",
        "backend",
        "backendVersion",
        "backendMode",
        "mode",
        "request",
        "sourceGeometryGate",
        "renderGate",
        "commands",
        "postProcessing",
        "responseSummary",
        "readmeMarkdown",
        "oefDocumentation"
      ],
      "additionalProperties": true,
      "properties": {
        "viewId": { "type": "string", "minLength": 1 },
        "viewpoint": { "type": "string" },
        "layoutIntent": {
          "enum": ["preserve-authored", "route-repair-only", "generated-layout-recreate", "global-reflow"]
        },
        "selectedGeometryPath": {
          "enum": [
            "layout-elk",
            "route-repair",
            "global-polish",
            "deterministic-fallback",
            "viewpoint-policy",
            "preserved-authored"
          ]
        },
        "backend": { "type": "string", "minLength": 1 },
        "backendVersion": { "type": "string" },
        "backendMode": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "minLength": 1 },
        "request": { "type": "string", "minLength": 1 },
        "result": { "type": "string", "minLength": 1 },
        "materializedOef": { "type": "string", "minLength": 1 },
        "sourceGeometryGate": { "type": "string", "minLength": 1 },
        "renderGate": { "type": "string", "minLength": 1 },
        "commands": {
          "type": "object",
          "required": ["geometry", "requestValidation", "resultValidation", "materialization", "renderValidation"],
          "additionalProperties": true,
          "properties": {
            "geometry": { "type": "string", "minLength": 1 },
            "requestValidation": { "type": "string", "minLength": 1 },
            "resultValidation": { "type": "string", "minLength": 1 },
            "materialization": { "type": "string", "minLength": 1 },
            "renderValidation": { "type": "string", "minLength": 1 }
          }
        },
        "postProcessing": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "pngValidation": {
          "type": "object",
          "required": ["path"],
          "additionalProperties": true,
          "properties": {
            "path": { "type": "string", "minLength": 1 }
          }
        },
        "responseSummary": { "type": "string", "minLength": 1 },
        "readmeMarkdown": { "type": "string", "minLength": 1 },
        "oefDocumentation": { "type": "string", "minLength": 1 }
      }
    }
  }
}
