<?xml version="1.0" encoding="UTF-8"?>
<!--
  Negative fixture: Service Realization view hides the main Realization spine.
-->
<model xmlns="http://www.opengroup.org/xsd/archimate/3.0/"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.opengroup.org/xsd/archimate/3.0/ http://www.opengroup.org/xsd/archimate3_Model.xsd"
       identifier="id-fixture-hidden-realization">

  <name xml:lang="en">Fixture - Hidden realization spine</name>

  <documentation xml:lang="en">Negative fixture for AD-L20: a Service Realization view contains both endpoints of a Realization relationship, but the relationship is hidden instead of drawn as the realization spine.</documentation>

  <elements>
    <element identifier="id-app-orders-api" xsi:type="ApplicationComponent">
      <name xml:lang="en">Orders API</name>
    </element>
    <element identifier="id-svc-place-order" xsi:type="ApplicationService">
      <name xml:lang="en">Place Order</name>
    </element>
  </elements>

  <relationships>
    <relationship identifier="id-rel-api-realizes-service"
                  source="id-app-orders-api"
                  target="id-svc-place-order"
                  xsi:type="Realization">
      <properties>
        <property propertyDefinitionRef="propid-archi-arm">
          <value xml:lang="en">hide</value>
        </property>
      </properties>
    </relationship>
  </relationships>

  <propertyDefinitions>
    <propertyDefinition identifier="propid-archi-arm" type="string">
      <name xml:lang="en">Archi ARM</name>
    </propertyDefinition>
  </propertyDefinitions>

  <views>
    <diagrams>
      <view identifier="id-view-hidden-realization"
            xsi:type="Diagram"
            viewpoint="Service Realization">
        <name xml:lang="en">Hidden realization spine</name>
        <documentation xml:lang="en">Both endpoints are visible, so the Realization relationship must be visible unless documented as non-spine redundancy.</documentation>
        <node identifier="id-node-place-order-service" elementRef="id-svc-place-order" xsi:type="Element" x="40" y="40" w="180" h="60"/>
        <node identifier="id-node-orders-api" elementRef="id-app-orders-api" xsi:type="Element" x="40" y="160" w="160" h="60"/>
      </view>
    </diagrams>
  </views>
</model>
