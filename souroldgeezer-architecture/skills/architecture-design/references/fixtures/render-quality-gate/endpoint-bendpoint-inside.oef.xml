<?xml version="1.0" encoding="UTF-8"?>
<!--
  Negative fixture: the final bendpoint sits inside the target endpoint box.
-->
<model xmlns="http://www.opengroup.org/xsd/archimate/3.0/"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.opengroup.org/xsd/archimate/3.0/ http://www.opengroup.org/xsd/archimate3_Model.xsd"
       identifier="id-fixture-endpoint-bendpoint-inside">

  <name xml:lang="en">Fixture - Endpoint bendpoint inside box</name>

  <documentation xml:lang="en">Negative fixture for endpoint route quality: the connector route is otherwise clean, but its final bendpoint is inside the target process node.</documentation>

  <elements>
    <element identifier="id-actor-operator" xsi:type="BusinessActor">
      <name xml:lang="en">Operator</name>
    </element>
    <element identifier="id-process-approve" xsi:type="BusinessProcess">
      <name xml:lang="en">Approve Order</name>
    </element>
  </elements>

  <relationships>
    <relationship identifier="id-rel-operator-approve" source="id-actor-operator" target="id-process-approve" xsi:type="Assignment"/>
  </relationships>

  <views>
    <diagrams>
      <view identifier="id-view-endpoint-bendpoint-inside"
            xsi:type="Diagram"
            viewpoint="Business Process Cooperation">
        <name xml:lang="en">Endpoint bendpoint inside box</name>
        <documentation xml:lang="en">The last bendpoint is inside Approve Order, so the renderer may snap through the process body even though no unrelated node is crossed.</documentation>
        <node identifier="id-node-operator" elementRef="id-actor-operator" xsi:type="Element" x="40" y="40" w="160" h="60"/>
        <node identifier="id-node-approve" elementRef="id-process-approve" xsi:type="Element" x="420" y="40" w="180" h="60"/>
        <connection identifier="id-conn-operator-approve"
                    relationshipRef="id-rel-operator-approve"
                    source="id-node-operator"
                    target="id-node-approve"
                    xsi:type="Relationship">
          <bendpoint x="250" y="70"/>
          <bendpoint x="450" y="70"/>
        </connection>
      </view>
    </diagrams>
  </views>
</model>
