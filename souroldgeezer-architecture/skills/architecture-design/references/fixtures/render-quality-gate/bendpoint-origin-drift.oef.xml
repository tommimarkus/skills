<?xml version="1.0" encoding="UTF-8"?>
<!--
  Negative fixture: all visible content is shifted away from the canvas origin.
  The smallest used-region coordinate comes from bendpoints, proving AD-L10
  checks node and bendpoint geometry together.
-->
<model xmlns="http://www.opengroup.org/xsd/archimate/3.0/"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.opengroup.org/xsd/archimate/3.0/ http://www.opengroup.org/xsd/archimate3_Model.xsd"
       identifier="id-fixture-bendpoint-origin-drift">

  <name xml:lang="en">Fixture - Bendpoint origin drift</name>

  <documentation xml:lang="en">Negative fixture for AD-L10: render cropping can hide that the source view's used-region origin comes from bendpoints at (80, 80), not the normalized canvas origin.</documentation>

  <elements>
    <element identifier="id-app-left" xsi:type="ApplicationComponent">
      <name xml:lang="en">Left App</name>
    </element>
    <element identifier="id-app-right" xsi:type="ApplicationComponent">
      <name xml:lang="en">Right App</name>
    </element>
  </elements>

  <relationships>
    <relationship identifier="id-rel-left-to-right" source="id-app-left" target="id-app-right" xsi:type="Serving"/>
  </relationships>

  <views>
    <diagrams>
      <view identifier="id-view-bendpoint-origin-drift"
            xsi:type="Diagram"
            viewpoint="Application Cooperation">
        <name xml:lang="en">Bendpoint origin drift</name>
        <documentation xml:lang="en">Node coordinates start at (120, 160), but the route bends through (80, 80), so AD-L10 must report min_x=80 and min_y=80.</documentation>
        <node identifier="id-node-left" elementRef="id-app-left" xsi:type="Element" x="120" y="160" w="140" h="60"/>
        <node identifier="id-node-right" elementRef="id-app-right" xsi:type="Element" x="420" y="160" w="140" h="60"/>
        <connection identifier="id-conn-left-to-right"
                    relationshipRef="id-rel-left-to-right"
                    source="id-node-left"
                    target="id-node-right"
                    xsi:type="Relationship">
          <bendpoint x="80" y="80"/>
          <bendpoint x="500" y="80"/>
        </connection>
      </view>
    </diagrams>
  </views>
</model>
