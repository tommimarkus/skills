{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://souroldgeezer.dev/schemas/architecture/layout-result.schema.json",
  "title": "Architecture layout result",
  "type": "object",
  "required": ["schemaVersion", "requestId", "backend", "mode", "deterministic", "readiness", "nodeGeometry", "edges", "metrics", "validation"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "requestId": { "type": "string", "minLength": 1 },
    "backend": {
      "type": "object",
      "required": ["name", "version", "mode", "deterministic"],
      "additionalProperties": true
    },
    "mode": { "enum": ["generated-layout", "route-repair", "global-polish"] },
    "deterministic": { "type": "boolean" },
    "readiness": { "enum": ["success", "warning", "capped"] },
    "nodeGeometry": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "x", "y", "w", "h"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "w": { "type": "integer", "minimum": 1 },
          "h": { "type": "integer", "minimum": 1 },
          "locked": { "type": "boolean" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "target", "sourcePort", "targetPort", "bendpoints", "route"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "sourcePort": { "type": "string" },
          "targetPort": { "type": "string" },
          "bendpoints": { "type": "array" },
          "route": {
            "type": "object",
            "required": ["status", "style"],
            "properties": {
              "status": { "type": "string" },
              "style": { "type": "string" }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "subjectIds"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "enum": ["info", "warning", "error"] },
          "message": { "type": "string" },
          "subjectIds": { "type": "array", "items": { "type": "string" } },
          "edgeId": { "type": "string" },
          "nodeId": { "type": "string" },
          "parentId": { "type": "string" },
          "childId": { "type": "string" },
          "nodeIds": { "type": "array", "items": { "type": "string" } },
          "relationship": { "type": "string" },
          "segment": {
            "type": "object",
            "required": ["x1", "y1", "x2", "y2"],
            "properties": {
              "x1": { "type": "integer" },
              "y1": { "type": "integer" },
              "x2": { "type": "integer" },
              "y2": { "type": "integer" }
            }
          },
          "nodeBounds": {
            "oneOf": [
              { "$ref": "#/$defs/rectangle" },
              { "type": "array", "items": { "$ref": "#/$defs/rectangle" } }
            ]
          },
          "parentBounds": { "$ref": "#/$defs/rectangle" },
          "childBounds": { "$ref": "#/$defs/rectangle" },
          "requested": { "$ref": "#/$defs/point" },
          "produced": { "$ref": "#/$defs/point" }
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "nodeOverlaps": { "type": "integer" },
        "sameParentNodeOverlaps": { "type": "integer" },
        "parentChildContainments": { "type": "integer" },
        "childOutsideParentBounds": { "type": "integer" },
        "connectorNodeIntersections": { "type": "integer" },
        "connectorUnrelatedNodeIntersections": { "type": "integer" },
        "connectorContainerBoundaryCrossings": { "type": "integer" },
        "connectorCrossings": { "type": "integer" }
      }
    },
    "validation": {
      "type": "object",
      "required": ["state"],
      "properties": {
        "state": { "enum": ["valid", "warning", "invalid"] }
      }
    }
  },
  "$defs": {
    "point": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" }
      }
    },
    "rectangle": {
      "type": "object",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "w": { "type": "integer" },
        "h": { "type": "integer" }
      }
    }
  }
}
