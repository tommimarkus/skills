{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/agent-hooks/stop-evaluate-skill.sh\"",
            "statusMessage": "Checking changed skills for plugin-eval evaluate-skill prompt"
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/agent-hooks/stop-plugin-eval.sh\"",
